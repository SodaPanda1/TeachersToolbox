<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 响应式断点 -->
    <x:Double x:Key="SmallScreenWidth">640</x:Double>
    <x:Double x:Key="MediumScreenWidth">1024</x:Double>
    <x:Double x:Key="LargeScreenWidth">1440</x:Double>

    <!-- 基础间距 -->
    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">16</x:Double>
    <x:Double x:Key="SpacingLarge">24</x:Double>
    <x:Double x:Key="SpacingXLarge">32</x:Double>

    <!-- 圆角 -->
    <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXLarge">16</CornerRadius>

    <!-- 卡片样式 -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
        <Setter Property="Padding" Value="{StaticResource SpacingMedium}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
    </Style>

    <!-- 页面容器样式 -->
    <Style x:Key="PageContainerStyle" TargetType="Grid">
        <Setter Property="Padding" Value="{StaticResource SpacingLarge}" />
        <Setter Property="RowSpacing" Value="{StaticResource SpacingMedium}" />
    </Style>

    <!-- 页面标题样式 -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- 工具栏样式 -->
    <Style x:Key="ToolbarStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="{StaticResource SpacingSmall}" />
        <Setter Property="Margin" Value="0,0,0,{StaticResource SpacingMedium})" />
    </Style>

    <!-- 统计卡片样式 -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
        <Setter Property="Padding" Value="{StaticResource SpacingMedium}" />
        <Setter Property="MinWidth" Value="120" />
    </Style>

    <!-- 快捷入口卡片样式 -->
    <Style x:Key="QuickActionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
        <Setter Property="Padding" Value="{StaticResource SpacingMedium}" />
        <Setter Property="Width" Value="180" />
        <Setter Property="Height" Value="120" />
    </Style>

    <!-- 网格容器样式 -->
    <Style x:Key="ResponsiveGridViewStyle" TargetType="GridView">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,-8,0,0" />
    </Style>

    <!-- 列表头样式 -->
    <Style x:Key="ListViewHeaderStyle" TargetType="Grid">
        <Setter Property="Padding" Value="8,12" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="ColumnSpacing" Value="{StaticResource SpacingMedium}" />
    </Style>

    <!-- 数据行样式 -->
    <Style x:Key="DataRowStyle" TargetType="Grid">
        <Setter Property="Padding" Value="8" />
        <Setter Property="ColumnSpacing" Value="{StaticResource SpacingMedium}" />
    </Style>

</ResourceDictionary>

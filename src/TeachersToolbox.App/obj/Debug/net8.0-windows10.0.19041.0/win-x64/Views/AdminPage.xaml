<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.AdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="28" FontWeight="Bold" Text="行政工具" />

        <GridView x:ConnectionId='2' Grid.Row="1" Padding="0,16,0,0"                            IsItemClickEnabled="True">
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="schedule">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE787;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="课程表" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="查看和管理课程表" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="attendance">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE77B;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="考勤管理" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="学生出勤记录" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="notification">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE715;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="通知生成" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="快速生成通知文本" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="export">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xEDE1;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="数据导出" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="导出Excel/CSV文件" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
        </GridView>
    </Grid>
</Page>


<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.RollCallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" MaxHeight="120" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="28" FontWeight="Bold" Text="随机点名" Margin="0,0,0,16" />

        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="500" Height="300" Padding="32"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="20" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center" Text="当前点名" />
                    <TextBlock x:Name="StudentNameText" FontSize="54" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,24,0,0" Text="准备好了吗？" />
                    <TextBlock x:Name="ClassInfoText" FontSize="16"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 班级选择和开关设置 - 固定位置 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" 
                    HorizontalAlignment="Center" Margin="0,16,0,0">
            <ComboBox x:Name="ClassComboBox" Width="200" Header="选择班级"
                      SelectionChanged="ClassComboBox_SelectionChanged" />
            <ToggleSwitch x:Name="RepeatToggle" Header="允许重复"
                          OffContent="不重复点名" OnContent="可重复点名" />
            <ToggleSwitch x:Name="AnimationToggle" Header="滚动动画"
                          OffContent="直接显示" OnContent="滚动效果" IsOn="True" />
        </StackPanel>

        <!-- 控制按钮 - 固定位置 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="16" 
                    HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button x:Name="StartButton" MinWidth="160" MinHeight="48"
                    Click="StartButton_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE768;" />
                    <TextBlock Text="开始点名" />
                </StackPanel>
            </Button>
            <Button x:Name="StopButton" MinWidth="160" MinHeight="48"
                    Click="StopButton_Click" IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE71A;" />
                    <TextBlock Text="停止" />
                </StackPanel>
            </Button>
            <Button x:Name="ResetButton" MinWidth="120" MinHeight="48"
                    Click="ResetButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE72C;" />
                    <TextBlock Text="重置" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 历史记录 - 限制高度，可滚动 -->
        <Border Grid.Row="4" Padding="12" Margin="0,16,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="14" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Text="最近点名：" Margin="0,0,0,4" />
                    <TextBlock x:Name="HistoryText" FontSize="14" TextWrapping="Wrap" Text="暂无记录" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>

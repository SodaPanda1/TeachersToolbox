<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TeachersToolbox.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="教师工具箱"
    mc:Ignorable="d">
    <Grid>
        <NavigationView x:Name="NavView" 
                        IsBackButtonVisible="Auto" 
                        IsSettingsVisible="True"
                        ItemInvoked="NavView_ItemInvoked" 
                        BackRequested="NavView_BackRequested"
                        Loaded="NavView_Loaded"
                        PaneDisplayMode="Auto" 
                        IsPaneOpen="True">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="主页" Icon="Home" Tag="home" />
                <NavigationViewItem Content="学生管理" Icon="People" Tag="students" />
                <NavigationViewItem Content="随机点名" Icon="Shuffle" Tag="rollcall" />
                <NavigationViewItem Content="成绩管理" Icon="Edit" Tag="scores" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.ClassroomPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="28" FontWeight="Bold" Text="课堂工具" />

        <GridView Grid.Row="1" Padding="0,16,0,0" ItemClick="ToolItem_Click" IsItemClickEnabled="True">
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="timer">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE916;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="课堂计时" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="倒计时/正计时工具" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="rollcall">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE8EC;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="随机点名" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="随机抽取学生回答" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="points">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE734;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="加减分板" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="课堂加减分管理" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="randomquestion">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE72C;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="随机抽题" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="从题库随机抽取题目" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
            <GridViewItem>
                <Border Width="200" Height="150" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        Tag="groups">
                    <StackPanel>
                        <FontIcon FontSize="32" Glyph="&#xE7EE;" />
                        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,12,0,0" Text="随机分组" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   Text="自动随机分组" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </GridViewItem>
        </GridView>
    </Grid>
</Page>

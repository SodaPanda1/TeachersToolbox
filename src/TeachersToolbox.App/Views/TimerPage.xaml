<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.TimerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="28" FontWeight="Bold" Text="课堂计时" />

        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="500" Height="450" Padding="32"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                    <TextBlock x:Name="TimerText" FontSize="96" FontWeight="Light"
                               HorizontalAlignment="Center" Text="00:00:00" />

                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Click="SetTime_Click" Tag="60">
                            <TextBlock Text="1分钟" />
                        </Button>
                        <Button Click="SetTime_Click" Tag="180">
                            <TextBlock Text="3分钟" />
                        </Button>
                        <Button Click="SetTime_Click" Tag="300">
                            <TextBlock Text="5分钟" />
                        </Button>
                        <Button Click="SetTime_Click" Tag="600">
                            <TextBlock Text="10分钟" />
                        </Button>
                        <Button Click="SetTime_Click" Tag="900">
                            <TextBlock Text="15分钟" />
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="分钟" Margin="0,0,0,8" />
                            <TextBox x:Name="MinutesBox" Width="80" Text="0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="秒" Margin="0,0,0,8" />
                            <TextBox x:Name="SecondsBox" Width="80" Text="0" />
                        </StackPanel>
                        <Button Click="SetCustomTime_Click" Margin="0,20,0,0">
                            设置
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                        <Button x:Name="StartButton" MinWidth="120" MinHeight="48"
                                Click="StartButton_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE768;" />
                                <TextBlock Text="开始" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PauseButton" MinWidth="120" MinHeight="48"
                                Click="PauseButton_Click" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE769;" />
                                <TextBlock Text="暂停" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ResetButton" MinWidth="120" MinHeight="48"
                                Click="ResetButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                <TextBlock Text="重置" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ToggleSwitch x:Name="CountdownToggle" Header="模式"
                                  OffContent="正计时" OnContent="倒计时" IsOn="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="TeachersToolbox.App.Views.ImportStudentsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="导入学生名单"
    PrimaryButtonText="确认导入"
    SecondaryButtonText="取消"
    DefaultButton="Primary"
    mc:Ignorable="d">

    <Grid MinWidth="700" MinHeight="500" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 文件选择 -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="选择Excel文件" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="FilePathBox" Width="500" IsReadOnly="True" 
                         PlaceholderText="点击右侧按钮选择文件..." />
                <Button x:Name="BrowseButton" Click="BrowseButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                        <TextBlock Text="浏览" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- 工作表和列选择 -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="工作表" FontWeight="SemiBold" />
                <ComboBox x:Name="WorksheetComboBox" Width="200" 
                          PlaceholderText="选择工作表"
                          SelectionChanged="WorksheetComboBox_SelectionChanged" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="姓名所在列" FontWeight="SemiBold" />
                <ComboBox x:Name="ColumnComboBox" Width="120"
                          PlaceholderText="选择列"
                          SelectionChanged="ColumnComboBox_SelectionChanged">
                    <ComboBoxItem Content="A" />
                    <ComboBoxItem Content="B" />
                    <ComboBoxItem Content="C" />
                    <ComboBoxItem Content="D" />
                    <ComboBoxItem Content="E" />
                    <ComboBoxItem Content="F" />
                    <ComboBoxItem Content="G" />
                    <ComboBoxItem Content="H" />
                    <ComboBoxItem Content="I" />
                    <ComboBoxItem Content="J" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                <CheckBox x:Name="SkipHeaderCheckBox" Content="第一行是标题"
                          IsChecked="True" 
                          Checked="SkipHeaderCheckBox_Changed" 
                          Unchecked="SkipHeaderCheckBox_Changed" />
            </StackPanel>
        </Grid>

        <!-- Excel 预览 -->
        <Border Grid.Row="2" 
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                BorderThickness="1" 
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Grid x:Name="PreviewGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 列头 -->
                    <Grid x:Name="HeaderGrid" Grid.Row="0" />

                    <!-- 数据行 -->
                    <Grid x:Name="DataGrid" Grid.Row="1" />
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 导入信息 -->
        <StackPanel Grid.Row="3" Spacing="4">
            <TextBlock x:Name="PreviewInfoText" 
                       Text="请选择Excel文件开始导入"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock x:Name="StudentCountText" 
                       Text=""
                       FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</ContentDialog>

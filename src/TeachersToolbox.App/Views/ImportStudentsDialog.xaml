<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="TeachersToolbox.App.Views.ImportStudentsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wv2="using:Microsoft.Web.WebView2.Core"
    Title="导入学生名单"
    PrimaryButtonText="确认导入"
    SecondaryButtonText="取消"
    DefaultButton="Primary"
    mc:Ignorable="d">

    <Grid MaxWidth="700" RowSpacing="12" Padding="12,8,12,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="250" MaxHeight="350" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 班级选择 -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="导入到班级" FontWeight="SemiBold" />
            <ComboBox x:Name="TargetClassComboBox" 
                      PlaceholderText="选择目标班级" />
        </StackPanel>

        <!-- 文件选择 -->
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="选择Excel文件" FontWeight="SemiBold" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathBox" 
                         IsReadOnly="True" 
                         PlaceholderText="点击右侧按钮选择文件..." />
                <Button x:Name="BrowseButton" 
                        Grid.Column="1"
                        Click="BrowseButton_Click"
                        Content="浏览..."
                        Padding="16,8" />
            </Grid>
        </StackPanel>

        <!-- 工作表和列选择 -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="工作表" FontWeight="SemiBold" />
                <ComboBox x:Name="WorksheetComboBox" 
                          PlaceholderText="选择工作表"
                          SelectionChanged="WorksheetComboBox_SelectionChanged" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="姓名所在列" FontWeight="SemiBold" />
                <ComboBox x:Name="ColumnComboBox" Width="90"
                          PlaceholderText="选择列"
                          SelectionChanged="ColumnComboBox_SelectionChanged">
                    <ComboBoxItem Content="A" />
                    <ComboBoxItem Content="B" />
                    <ComboBoxItem Content="C" />
                    <ComboBoxItem Content="D" />
                    <ComboBoxItem Content="E" />
                    <ComboBoxItem Content="F" />
                    <ComboBoxItem Content="G" />
                    <ComboBoxItem Content="H" />
                    <ComboBoxItem Content="I" />
                    <ComboBoxItem Content="J" />
                </ComboBox>
            </StackPanel>

            <CheckBox Grid.Column="2" 
                      x:Name="SkipHeaderCheckBox" 
                      Content="第一行是标题"
                      VerticalAlignment="Bottom"
                      IsChecked="True" 
                      Checked="SkipHeaderCheckBox_Changed" 
                      Unchecked="SkipHeaderCheckBox_Changed" />
        </Grid>

        <!-- Excel 预览 - 使用 WebView2 -->
        <Border Grid.Row="3" 
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                BorderThickness="1" 
                CornerRadius="4">
            <WebView2 x:Name="PreviewWebView" />
        </Border>

        <!-- 导入信息 -->
        <StackPanel Grid.Row="4" Spacing="4" Padding="0,8,0,0">
            <TextBlock x:Name="PreviewInfoText" 
                       Text="请选择Excel文件开始导入"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock x:Name="StudentCountText" 
                       Text=""
                       FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</ContentDialog>

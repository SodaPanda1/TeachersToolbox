<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="800" HorizontalAlignment="Left" Spacing="24">
            <TextBlock FontSize="28" FontWeight="Bold" Text="设置" />

            <!-- 外观设置 -->
            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="16">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="外观设置" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="主题：" VerticalAlignment="Center" />
                        <ComboBox x:Name="ThemeComboBox" Width="150" SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="跟随系统" Tag="Default" />
                            <ComboBoxItem Content="浅色" Tag="Light" />
                            <ComboBoxItem Content="深色" Tag="Dark" />
                        </ComboBox>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Text="更改主题后需要重启应用才能完全生效" />
                </StackPanel>
            </Border>

            <!-- 数据管理 -->
            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="16">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="数据管理" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="ExportButton" Click="ExportButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xEDE1;" />
                                <TextBlock Text="导出数据" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportButton" Click="ImportButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                                <TextBlock Text="导入数据" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BackupButton" Click="BackupButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE78E;" />
                                <TextBlock Text="备份数据库" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Text="导入数据会覆盖现有数据，请谨慎操作" />
                </StackPanel>
            </Border>

            <!-- 数据库信息 -->
            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="数据库信息" />
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Text="班级数" />
                            <TextBlock x:Name="ClassCountText" FontSize="24" FontWeight="Bold" Text="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Text="学生数" />
                            <TextBlock x:Name="StudentCountText" FontSize="24" FontWeight="Bold" Text="0" />
                        </StackPanel>
                    </Grid>
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                            <TextBlock Text="刷新统计" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 关于 -->
            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="关于" />
                    <TextBlock FontSize="16" Text="教师工具箱" />
                    <TextBlock Text="版本：1.0.0" />
                    <TextBlock Text="基于 WinUI 3 + .NET 10 开发" />
                    <TextBlock Text="许可证：GNU General Public License v3.0 (GPLv3)" />
                    <HyperlinkButton Content="GitHub 仓库" NavigateUri="https://github.com/SodaPanda1/TeachersToolbox" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

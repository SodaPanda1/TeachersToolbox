<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.StudentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="28" FontWeight="Bold" Text="学生管理" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <StackPanel>
                <TextBlock Text="选择班级" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="ClassComboBox" Width="180" 
                              SelectionChanged="ClassComboBox_SelectionChanged" />
                    <Button x:Name="AddClassButton" Click="AddClassButton_Click"
                            ToolTipService.ToolTip="添加班级">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                    </Button>
                    <Button x:Name="DeleteClassButton" Click="DeleteClassButton_Click"
                            ToolTipService.ToolTip="删除班级">
                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    </Button>
                </StackPanel>
            </StackPanel>
            <TextBox x:Name="SearchBox" Width="180" Header="搜索" PlaceholderText="输入姓名搜索" />
            <Button x:Name="ImportButton" Click="ImportButton_Click" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                    <TextBlock Text="从Excel导入" />
                </StackPanel>
            </Button>
            <Button x:Name="RollCallButton" Click="RollCallButton_Click" Margin="0,20,0,0"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE8EC;" />
                    <TextBlock Text="随机点名" />
                </StackPanel>
            </Button>
        </StackPanel>

        <ListView Grid.Row="2" x:Name="StudentListView">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ClassName}" 
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Student.Name}" FontWeight="Medium" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TeachersToolbox.App.Views.StudentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="28" FontWeight="Bold" Text="学生管理" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="ClassComboBox" Width="200" Header="选择班级" SelectionChanged="ClassComboBox_SelectionChanged">
                <ComboBoxItem Content="高一(1)班" Tag="1" />
                <ComboBoxItem Content="高一(2)班" Tag="2" />
                <ComboBoxItem Content="高一(3)班" Tag="3" />
            </ComboBox>
            <TextBox x:Name="SearchBox" Width="200" Header="搜索" PlaceholderText="输入姓名搜索" />
            <Button x:Name="ImportButton" Click="ImportButton_Click" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                    <TextBlock Text="从Excel导入" />
                </StackPanel>
            </Button>
            <Button x:Name="AddButton" Click="AddButton_Click" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock Text="添加学生" />
                </StackPanel>
            </Button>
            <Button x:Name="RollCallButton" Click="RollCallButton_Click" Margin="0,20,0,0"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE8EC;" />
                    <TextBlock Text="随机点名" />
                </StackPanel>
            </Button>
        </StackPanel>

        <ListView Grid.Row="2" x:Name="StudentListView" IsItemClickEnabled="True" 
                  ItemClick="StudentListView_ItemClick">
            <ListView.Header>
                <Grid Padding="8,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <TextBlock FontWeight="Medium" Text="姓名" />
                </Grid>
            </ListView.Header>
        </ListView>
    </Grid>
</Page>
